// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String   @id @default(uuid())
  sku             String?  @unique
  name            String
  description     String   @db.Text
  shortDescription String? @db.Text
  price           Float
  image           String
  category        String
  isFeatured      Boolean  @default(false)
  stock           Int      @default(0)
  isSupplierStock Boolean  @default(false)
  costPrice       Float    @default(0)
  warrantyPeriod  String?  
  condition       String   @default("New")
  orderItems      OrderItem[]
  serialNumbers   SerialNumber[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  images          ProductImage[]
  categories      Category[]
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique // Keeping unique for simplicity in imports
  slug      String?  @unique
  isFeatured Boolean  @default(false)
  
  parentId  String?
  parent    Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[]  @relation("CategoryHierarchy")
  
  products  Product[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?    // Optional for invited users who haven't set it yet
  role          String    @default("customer")
  name          String?
  contactNumber String?
  address       String?
  resetToken    String?   @unique
  resetTokenExpiry DateTime?
  orders        Order[]
  quotes        Quote[]   @relation("CustomerQuotes")
  invoices      Invoice[] @relation("CustomerInvoices")
  
  createdQuotes   Quote[]   @relation("SalesPersonQuotes")
  createdInvoices Invoice[] @relation("SalesPersonInvoices")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id        String      @id @default(uuid())
  total     Float
  status    String      @default("Pending")
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  userId    String?     // Nullable for guest checkout if needed, but for logged in users strictly link it
  user      User?       @relation(fields: [userId], references: [id])
  invoice   Invoice?

  // Guest / Shipping Details
  customerName    String?
  customerEmail   String?
  shippingAddress String?
  paymentMethod   String?  @default("eft") // eft, cash
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  serialNumbers SerialNumber[]
}

model Quote {
  id           String      @id @default(uuid())
  total        Float
  status       String      @default("Draft") // Draft, Sent, Accepted, Rejected, Invoiced
  customerName String?     // Snapshot for quick display or non-registered users
  customerEmail String?    // Snapshot
  items        QuoteItem[]
  
  userId       String?
  user         User?       @relation("CustomerQuotes", fields: [userId], references: [id])
  
  salesPersonId String?
  salesPerson   User?      @relation("SalesPersonQuotes", fields: [salesPersonId], references: [id])
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  expiresAt    DateTime?
  invoice      Invoice?
}

model QuoteItem {
  id          String  @id @default(uuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id])
  productId   String? // Optional if custom item
  name        String
  price       Float
  quantity    Int
  isCustom    Boolean @default(false)
  warranty    String?
}

model Invoice {
  id        String   @id @default(uuid())
  total     Float
  status    String   @default("Unpaid") // Unpaid, Paid, Overdue
  customerName String?
  customerEmail String?
  
  orderId   String?  @unique
  order     Order?   @relation(fields: [orderId], references: [id])
  
  quoteId   String?  @unique
  quote     Quote?   @relation(fields: [quoteId], references: [id])
  
  userId    String?  // Optional if invoice for guest
  user      User?    @relation("CustomerInvoices", fields: [userId], references: [id])
  
  salesPersonId String?
  salesPerson   User?      @relation("SalesPersonInvoices", fields: [salesPersonId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dueDate   DateTime?
  serialNumbers SerialNumber[]
}

model SerialNumber {
  id          String     @id @default(uuid())
  serial      String     @unique
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  
  status      String     @default("IN_STOCK") // IN_STOCK, SOLD, RMA, RETURNED
  
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  
  invoiceId   String?
  invoice     Invoice?   @relation(fields: [invoiceId], references: [id])
  soldAt      DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BankDetail {
  id            String   @id @default(uuid())
  bankName      String
  accountName   String
  accountNumber String
  branchCode    String
  isVisible     Boolean  @default(true) // To toggle display without deleting
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
